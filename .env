#NODE_ENV=production #dev, production

# Credential=======================
WEB_SECURE=false #SSL Enable # ignore or "false" if use Proxy
# Credential=======================

# Web & API ==============================================================
WEB_ENABLE=true
WEB_HOST=0.0.0.0 #Web host [public=0.0.0.0, local=127.0.0.1]
WEB_PORT=5001 #Web port
# Web & API ==============================================================


# JWT ==============================================================
