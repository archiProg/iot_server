# socket.io as bridge ==============================================================
BRIDGE_ENABLE=true
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8888
# WebsocketServer ==============================================================

# BRIDGE ==============================================================
BRIDGE_URL=http://127.0.0.1:8888
# BRIDGE ==============================================================

# WebsocketServer ==============================================================
WS_ENABLE=true
WS_HOST=0.0.0.0 #Websocket host [public=0.0.0.0, local=127.0.0.1]
WS_PORT=8000 #Websocket port
WS_PATH=/echo #Websocket path "/sample" , "/"
# WebsocketServer ==============================================================

# TCP server ==============================================================
TCP_ENABLE=true
TCP_HOST=0.0.0.0 #[public=0.0.0.0, local=127.0.0.1]
TCP_PORT=20133 #port
# WebsocketServer ==============================================================

